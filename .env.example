# MRO Teknik Dokümantasyon Aracısı — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın.

# ── LLM Provider (birini seçin) ──────────────────────────────────────────────

# SEÇENEK 1: Ollama — Tamamen ücretsiz, tamamen lokal (ÖNERİLEN)
# Kurulum: https://ollama.com  |  Model indirme: ollama pull deepseek-r1:8b
LLM_PROVIDER=ollama
# LLM_MODEL=deepseek-r1:8b    # Varsayılan. Değiştirmek için yorumu kaldırın.

# SEÇENEK 2: Groq — Ücretsiz bulut API, çok hızlı
# API key: https://console.groq.com (ücretsiz kayıt)
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile   # veya: mixtral-8x7b-32768, gemma2-9b-it

# SEÇENEK 3: Anthropic — Ücretli
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...
# LLM_MODEL=claude-sonnet-4-6

# ── Embedding (her zaman lokal/ücretsiz) ─────────────────────────────────────
EMBEDDING_MODE=local
# VOYAGE_API_KEY=   # Opsiyonel: daha iyi embedding için

# ── Genel Ayarlar ─────────────────────────────────────────────────────────────
MRO_DOCS_DIR=D:\mro_docs
N8N_BASE_URL=http://localhost:5678
